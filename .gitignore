### .NET / C# 核心忽略项 ###
bin/
obj/

# 编译输出和临时文件
[Dd]ebug/
[Rr]elease/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/

### IDE (Visual Studio / VS Code) 忽略项 ###
.vscode/
.vs/
*.user
*.userosscache
*.sln.docstates

### NuGet 包忽略项 ###
packages/
*.nupkg
# 如果使用 dotnet restore 产生的临时文件
project.lock.json
project.fragment.lock.json

### 操作系统临时文件 ###
Thumbs.db
.DS_Store

